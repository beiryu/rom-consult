# Backend env template.
# - Deploy: copy to `.env` on server.
# - Local: copy to `.env.local` on your machine.
#
# ==============================================
# APPLICATION SETTINGS
# ==============================================
APP_ENV="local"
APP_NAME="romconsult"
APP_DEBUG=true
APP_LOG_LEVEL="debug"

# Public frontend URL (emails, redirects, etc.)
APP_FRONTEND_URL="http://localhost.com"

# CORS Origins - comma separated list of allowed origins
APP_CORS_ORIGINS="http://localhost:3000" # comma-separated: "http://localhost:3000,https://yourdomain.com"

# ==============================================
# HTTP SERVER CONFIGURATION
# ==============================================
HTTP_HOST="0.0.0.0"
HTTP_PORT=3001
HTTP_VERSIONING_ENABLE=true
HTTP_VERSION=1

# ==============================================
# ERROR TRACKING - SENTRY
# ==============================================
# Get your DSN from https://sentry.io/
SENTRY_DSN=""

# ==============================================
# AUTHENTICATION & JWT
# ==============================================
# Generate strong random secrets for production
# You can use: openssl rand -base64 32
AUTH_ACCESS_TOKEN_SECRET="F2eKKbcHHyZdSn/06IbgQyKJBJa33rR8Gdg95jk8mO0="
AUTH_REFRESH_TOKEN_SECRET="Ut7OYHREHPyWRA9Xt12IhhLokH2IWsHcY0DpIEwbX6s="
AUTH_ACCESS_TOKEN_EXP="1d"
AUTH_REFRESH_TOKEN_EXP="7d"

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# Local Postgres credentials for docker-compose (edit these as needed)
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="master123"
POSTGRES_DB="postgres"

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?schema=public
DATABASE_URL="postgresql://postgres:master123@localhost:5432/postgres?schema=public"

# ==============================================
# SUPABASE (STORAGE)
# ==============================================
SUPABASE_URL="https://pegucwoschqnmnnexpwu.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBlZ3Vjd29zY2hxbm1ubmV4cHd1Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2OTQzOTMzNiwiZXhwIjoyMDg1MDE1MzM2fQ.vQCzB7nsygwGYrMx1G-IaM9SHp8eFA8gSyoj9z5fzkE"
SUPABASE_STORAGE_BUCKET_USER_UPLOADS=user-uploads
SUPABASE_STORAGE_BUCKET_PUBLIC_ASSETS=public-assets
SUPABASE_STORAGE_PRESIGN_EXPIRES=1200

# ==============================================
# RESEND (EMAIL)
# ==============================================
RESEND_API_KEY=re_YqMbBYG5_VrSpkQXPwAFizUUFV9inyDkZ
RESEND_FROM_EMAIL=onboarding@resend.dev

# ==============================================
# REDIS CONFIGURATION
# ==============================================
# REDIS_HOST="redis"
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_ENABLE_TLS=false

# ==============================================
# ADDITIONAL NOTES
# ==============================================
# 1. For production, use environment-specific values
# 2. Never commit real credentials to version control
# 3. Use workload identity / IAM roles when running on cloud infrastructure
# 4. Enable Redis AUTH and TLS for production environments
# 5. Use a managed database service for production
# 6. Store crypto mnemonics in a secrets manager (e.g. Vault, cloud SM)
# 7. Use mainnet networks for production (set TATUM_TESTNET=false)
# 8. Generate unique mnemonics for each cryptocurrency
# 9. Backup mnemonics securely (offline, encrypted)
# 10. Never log private keys or mnemonics
