# Copy to .env.production on the server (never commit real secrets).
# Hybrid deploy: Postgres + Redis in Docker bound to 127.0.0.1; Nest runs on host (PM2).

APP_ENV=production
APP_NAME=romconsult
APP_DEBUG=false
APP_LOG_LEVEL=info

APP_FRONTEND_URL=https://your-domain.com
APP_CORS_ORIGINS=https://your-domain.com

HTTP_HOST=0.0.0.0
HTTP_PORT=3001
HTTP_VERSIONING_ENABLE=true
HTTP_VERSION=1

SENTRY_DSN=

AUTH_ACCESS_TOKEN_SECRET=change-me-openssl-rand-base64-32
AUTH_REFRESH_TOKEN_SECRET=change-me-openssl-rand-base64-32
AUTH_ACCESS_TOKEN_EXP=1d
AUTH_REFRESH_TOKEN_EXP=7d

# Match docker-compose.db.yml / root .env POSTGRES_* and Redis password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=postgres

DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/postgres?schema=public

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis
REDIS_ENABLE_TLS=false

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_USER_UPLOADS=user-uploads
SUPABASE_STORAGE_BUCKET_PUBLIC_ASSETS=public-assets
SUPABASE_STORAGE_PRESIGN_EXPIRES=1200

RESEND_API_KEY=
RESEND_FROM_EMAIL=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
