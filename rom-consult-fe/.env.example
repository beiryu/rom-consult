# Frontend env template
# - Deploy: copy to `.env` in rom-consult-fe before build.
# - Local: copy to `.env.local` in rom-consult-fe.
#
# This value is used at build time in `src/lib/api-client.ts`:
#   baseURL = `${NEXT_PUBLIC_API_BASE_URL}/v1`
#
# With Nginx reverse proxy, keep this as `/api`.
NEXT_PUBLIC_API_BASE_URL=/api
