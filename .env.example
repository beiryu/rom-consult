# Root .env — used by docker compose for interpolation (Postgres/Redis passwords, etc.)

POSTGRES_USER=postgres
POSTGRES_PASSWORD=master123
POSTGRES_DB=postgres

REDIS_PASSWORD=redis-password

# Frontend build/runtime when using full Docker stack (see docker-compose.yml)
NEXT_PUBLIC_API_BASE_URL=/api

APP_FRONTEND_URL=http://localhost
APP_CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Hybrid deploy (docker-compose.db.yml + PM2 + Nginx on host)
# -----------------------------------------------------------------------------
# 1) Start DB only:
#    docker compose -f docker-compose.db.yml --env-file .env up -d
# 2) In rom-consult-be/.env.production set:
#    DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/DB?schema=public
#    REDIS_HOST=127.0.0.1
#    REDIS_PASSWORD=<same as REDIS_PASSWORD above>
# 3) Build + PM2: see ecosystem.config.cjs and nginx/nginx.host.conf
# 4) NEXT_PUBLIC_API_BASE_URL=/api must be set at `next build` time for the browser.
